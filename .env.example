# Gawk environment variables — public template.
#
# Server-side secrets are configured in Vercel and are NOT listed here.
# The full var inventory (Resend, Upstash, Turnstile, GitHub PAT, token
# signing, admin basic-auth, subscriber email encryption, etc.) lives
# in the private vault — listing every name here was handing attackers
# a roadmap of the system's external dependencies.
#
# To populate `.env.local` for local dev:
#   ~/.secrets/populate-env.sh aipulse
# (Reads the canonical names from macOS Keychain. See the private vault
# for the manifest.)

# Canonical site URL — used for email links + redirects.
# Production: https://gawk.dev. Local: http://localhost:3000.
NEXT_PUBLIC_SITE_ORIGIN=https://gawk.dev

# Beta gate for the email-capture modal.
# Values: "off" (query + cookie only) | "all" (modal shown to every visitor).
NEXT_PUBLIC_BETA_ENABLED=off

# Public community URL — destination of the "Community" link. Currently
# points at GitHub Discussions while the Discord server is being
# provisioned (the legacy name `NEXT_PUBLIC_DISCORD_INVITE_URL` is still
# read as a fallback so existing Vercel envs keep working). When neither
# is set, the link doesn't render — graceful degradation per CLAUDE.md.
NEXT_PUBLIC_COMMUNITY_URL=
