# AI Pulse environment variables
# Copy to .env.local for local dev. Never commit real values.
# Secrets live in macOS Keychain; populate via ~/.secrets/populate-env.sh aipulse.

# ---- Upstash Redis (ingest + cache) -----------------------------------------
# Vercel env only. Never exposed to the browser.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- GitHub Events API (globe dots + registry) ------------------------------
# Repo secret + Vercel env. Authenticated rate limit 5000 req/hr.
GH_TOKEN=

# ---- Cron-driven ingest shared secret ---------------------------------------
# Used by GH Actions workflows and /api/cron-health/record.
INGEST_SECRET=

# ---- Email capture (session 33) ---------------------------------------------
# Resend transactional API key. From the Resend dashboard after domain verify.
RESEND_API_KEY=
# Configured sender identity. Must match Resend-verified domain.
EMAIL_FROM_ADDRESS="AI Pulse <digest@aipulse.dev>"
# Where DMARC aggregate reports are delivered. Use the domain-registration email.
DMARC_RUA_EMAIL=

# ---- Cloudflare Turnstile (bot gate on subscribe form) ----------------------
# Site key is public (ships to the browser); secret key is server-side only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Token signing (confirm / unsubscribe links) ----------------------------
# HMAC secret for signed ULIDs in email links. Rotate quarterly.
# Generate: `openssl rand -hex 32`
TOKEN_SIGNING_SECRET=

# ---- Beta gate for the email-capture modal ----------------------------------
# Values: "off" (query + cookie only) | "all" (modal shown to every visitor).
# Stays "off" until the S34 daily digest ships — capturing emails without a
# digest to send is a broken promise.
NEXT_PUBLIC_BETA_ENABLED=off

# ---- Canonical site URL (used for email links + redirects) ------------------
# Production: https://aipulse-pi.vercel.app (or https://aipulse.dev once DNS cuts).
# Local: http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
