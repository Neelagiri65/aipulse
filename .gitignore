# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design-system handoff bundle (reference only, not part of the build)
/wmsample

# claude code local session state — never committed
/.claude

# Playwright visual smoke test artefacts — screenshots, traces, reports
# are run-specific outputs, not part of the checked-in code.
/test-results
/playwright-report
/playwright/.cache

# Operator screenshots (admin/ledger views, confirmation emails, etc.)
# can carry plaintext PII — keep them local-only on this public repo.
/screenshots

# Private docs — live in ~/Obsidian/agent-vault/projects/aipulse/.
# Session handoffs, internal PRDs, research findings, design specs, and the
# archived session log are intelligence, not code, and don't belong in the
# public repo. Keep the patterns here so stray local copies are never
# accidentally tracked.
/HANDOFF.md
/docs/AI_PULSE_V3_SPEC.md
/docs/handoff-archive.md
/docs/design-spec-v2.md
/docs/prd-*.md
/docs/issues-*.md
/docs/research-*.md

# Video pipeline generated artifacts
/data/video-daily.json
/data/video-narration.mp3
/public/video-narration.mp3
/public/video-screenshots/
